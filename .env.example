ARSONIST_API_TOKEN=change-me-token
ARSONIST_PROVISIONER_TOKEN=change-me-provisioner-token

# Optional HA / Postgres (jobs + queue + advisory leadership)
# ARSONIST_DATABASE_URL=postgresql://arsonist:arsonist@localhost:5432/arsonist
# ARSONIST_COORDINATOR_MODE=postgres

# Optional node JWT + signed job payloads (set the same signing key on control plane and nodes)
# ARSONIST_JWT_SECRET=change-me-jwt-secret
# ARSONIST_JOB_SIGNING_KEY=change-me-job-hmac-key

# Optional discovery
# ARSONIST_DISCOVERY_MODE=heartbeat
# ARSONIST_DISCOVERY_CIDR=172.28.0.0/24

# v12 multi-tenant AI cloud (optional; wraps /v1 + adds /v12 SaaS API)
# ARSONIST_V12_MULTITENANT=1
# ARSONIST_JWT_SECRET=change-me-jwt-secret
# ARSONIST_V12_BOOTSTRAP_TOKEN=change-me-bootstrap
# ARSONIST_REDIS_URL=redis://redis:6379/0
# ARSONIST_V12_ALLOW_LEGACY_INFERENCE=true
# ARSONIST_V12_WEBHOOK_URL=https://example.com/hooks/arsonist
